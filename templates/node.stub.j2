{% for e in node.enums %}
pub enum {{ e.enum_name }} {
    {% for v in e.variants %}
    {{ v.name }},
    {% endfor %}
}
{% endfor %}
pub struct {{ node.struct_name }};

impl {{ node.struct_name }} {
    pub fn new(name: &str) -> Self;
    pub fn add_spare<S: Into<houdini_ramen_core::types::SpareParam>>(self, spare: S) -> Self;

    {% if node.max_inputs > 0 %}
    pub fn set_input_at<O: Into<houdini_ramen_core::types::NodeOutput>>(self, index: usize, output: O) -> Self;
    {% if node.max_inputs >= 9999 %}
    pub fn add_input<O: Into<houdini_ramen_core::types::NodeOutput>>(self, output: O) -> Self;
    {% else %}
    pub fn set_input<O: Into<houdini_ramen_core::types::NodeOutput>>(self, output: O) -> Self;
    {% for inp in node.inputs %}
    pub fn set_{{ inp.safe_name }}_input<O: Into<houdini_ramen_core::types::NodeOutput>>(self, output: O) -> Self;
    {% if inp.safe_input_name %}
    pub fn set_input_name_{{ inp.safe_input_name }}<O: Into<houdini_ramen_core::types::NodeOutput>>(self, output: O) -> Self;
    {% endif %}
    {% endfor %}
    {% endif %}
    {% endif %}

    {% set ns = namespace(last_variant='') %}
    {% for p in node.params | sort(attribute='enum_variant') %}
    {% if p.enum_variant != ns.last_variant %}
    {% set ns.last_variant = p.enum_variant %}
    {% endif %}
    {% if p.is_multiparm %}
    {% if p.r_type == "()" %}
    pub fn trigger_{{ p.method_suffix }}(self, {{ p.fn_args }}) -> Self;
    {% else %}
    pub fn with_{{ p.method_suffix }}(self, {{ p.fn_args }}, val: {{ p.r_type }}) -> Self;
    pub fn with_{{ p.method_suffix }}_expr(self, {{ p.fn_args }}, expr: &str) -> Self;
    {% endif %}
    {% else %}
    {% if p.r_type == "()" %}
    pub fn trigger_{{ p.method_suffix }}(self) -> Self;
    {% else %}
    pub fn with_{{ p.method_suffix }}(self, val: {{ p.r_type }}) -> Self;
    pub fn with_{{ p.method_suffix }}_expr(self, expr: &str) -> Self;
    {% endif %}
    {% endif %}
    {% endfor %}
}

{% if node.output_enum %}
pub trait {{ node.struct_name }}Outputs {
    {% for v in node.output_enum.variants %}
    fn out_{{ v.method_name | replace('r#', '') }}(&self) -> houdini_ramen_core::types::NodeOutput;
    {% endfor %}
}
{% endif %}

{% if node.inner_methods %}
pub trait {{ node.struct_name }}InnerExt {
    {% for m in node.inner_methods %}
    fn {{ m.method_name }}(&mut self) -> houdini_ramen_core::graph::ExistingNodeRef;
    {% endfor %}
}
{% endif %}
