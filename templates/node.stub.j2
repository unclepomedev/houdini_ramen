    {% if node.max_inputs >= 9999 %}
    pub fn add_input<N: crate::core::types::HoudiniNode>(self, target: &N) -> Self;
    pub fn add_input_from<N: crate::core::types::HoudiniNode>(self, target: &N, output_index: usize) -> Self;
    {% else %}
    pub fn set_input<N: crate::core::types::HoudiniNode>(self, target: &N) -> Self;
    pub fn set_input_from<N: crate::core::types::HoudiniNode>(self, target: &N, output_index: usize) -> Self;
    {% for inp in node.inputs %}
    /// Connects to input {{ inp.index }}: "{{ inp.doc_label }}"
    pub fn set_input_{{ inp.safe_name }}<N: crate::core::types::HoudiniNode>(self, target: &N) -> Self;
    /// Connects to input {{ inp.index }}: "{{ inp.doc_label }}" and specifies the output index of the target node.
    pub fn set_input_{{ inp.safe_name }}_from<N: crate::core::types::HoudiniNode>(self, target: &N, output_index: usize) -> Self;
    {% endfor %}
    {% endif %}
    {% endif %}

    {% set ns = namespace(last_variant='') %}
    {% for p in node.params | sort(attribute='enum_variant') %}
